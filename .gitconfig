[alias]
	amend = commit --amend --no-edit
	abort = ! [ -f .git/CHERRY_PICK_HEAD ] && git cherry-pick --abort || ([ -f .git/MERGE_HEAD ] && git merge --abort || git rebase --abort)
	continue = ! [ -f .git/CHERRY_PICK_HEAD ] && git cherry-pick --continue || ([ -f .git/MERGE_HEAD ] && git merge --continue || git rebase --continue)
	force = push --force-with-lease
	g = graph
	graph = l --graph --exclude refs/stash --branches
	l = log --pretty=tformat:'%C(auto)%h %C(cyan)%ad %C(171)<%an>%C(auto)%d %s' --date=short
	ll = l -20
	patch = add --patch
	st = status -sb
[core]
	editor = helix
	autocrlf = false
	eol = lf
	excludesFile = ~/.gitignore
	pager = less -+X -x5,9
[grep]
	lineNumber = true
	patternType = perl
[commit]
	verbose = true
	gpgsign = true
[init]
	defaultBranch = "main"
[interactive]
	singleKey = true
[log]
	date = iso-local
[pager]
	branch = false
	stash = false
[pull]
	rebase = true
[rebase]
	updateRefs = true
	autosquash = true
[tag]
	gpgsign = true
